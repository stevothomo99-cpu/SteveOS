# HubSpot private app token. Keep this server-side only.
HUBSPOT_PRIVATE_APP_TOKEN=

# Internal HubSpot contact property name for the label "FocablyED Source".
HUBSPOT_SOURCE_PROPERTY=focablyed_source
HUBSPOT_SITEMARGIN_SOURCE=SiteMargin Waitlist
HUBSPOT_FOCABLY_SOURCE=FocablyED Waitlist
HUBSPOT_YFD_SOURCE=YFD Lead

# App login. JSON array of authorised users.
# Example only: use strong unique passwords in Vercel and never commit real credentials.
STEVEOS_USERS=[{"email":"steve@example.com","password":"change-me","name":"Steve"},{"email":"kim@example.com","password":"change-me-too","name":"Kim"}]

# Long random secret used to sign login cookies.
STEVEOS_AUTH_SECRET=replace-with-a-long-random-secret
